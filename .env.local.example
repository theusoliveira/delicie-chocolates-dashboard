# Supabase
# Acesse https://supabase.com/dashboard → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY

# Credenciais de acesso ao sistema
# IMPORTANTE: Altere esses valores antes de publicar em produção
APP_USERNAME=delicie.chocolates
APP_PASSWORD=delicie@2026

# Segredo para assinar o cookie de sessão (gere um valor aleatório forte em produção)
# Exemplo: openssl rand -base64 32
AUTH_SECRET=troque-por-um-segredo-forte-em-producao
